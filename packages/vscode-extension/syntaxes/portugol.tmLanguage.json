{
  "name": "Portugol",
  "scopeName": "source.portugol",
  "fileTypes": ["pjs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#pagina-declaration" },
    { "include": "#secao-declaration" },
    { "include": "#funcao-declaration" },
    { "include": "#modelo-declaration" },
    { "include": "#rota-declaration" },
    { "include": "#keywords-componentes-visuais" },
    { "include": "#keywords-componentes-novos" },
    { "include": "#keywords-layout" },
    { "include": "#keywords-api" },
    { "include": "#keywords-logica" },
    { "include": "#keywords-estilos" },
    { "include": "#keywords-tipos-modelo" },
    { "include": "#keywords-icones" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#braces" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.number-sign.portugol",
      "match": "#.*$"
    },

    "strings": {
      "name": "string.quoted.double.portugol",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.portugol",
          "match": "\\\\."
        }
      ]
    },

    "numbers": {
      "name": "constant.numeric.portugol",
      "match": "\\b[0-9]+(\\.[0-9]+)?%?\\b"
    },

    "pagina-declaration": {
      "comment": "pagina NomeDaPagina { — keyword + nome da página em destaque",
      "match": "\\b(pagina)\\s+([A-Za-zÀ-ÿ_][A-Za-zÀ-ÿ0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.pagina.portugol" },
        "2": { "name": "entity.name.type.pagina.portugol" }
      }
    },

    "secao-declaration": {
      "comment": "secao NomeDaSecao { — keyword + nome opcional da secção",
      "match": "\\b(secao)(?:\\s+([A-Za-zÀ-ÿ_][A-Za-zÀ-ÿ0-9_]*))?\\b",
      "captures": {
        "1": { "name": "support.class.secao.portugol" },
        "2": { "name": "entity.name.section.portugol" }
      }
    },

    "funcao-declaration": {
      "comment": "funcao nomeDaFuncao(params) {",
      "match": "\\b(funcao)\\s+([a-zA-ZÀ-ÿ_][a-zA-ZÀ-ÿ0-9_]*)\\s*(\\()",
      "captures": {
        "1": { "name": "keyword.declaration.funcao.portugol" },
        "2": { "name": "entity.name.function.portugol" },
        "3": { "name": "punctuation.definition.parameters.begin.portugol" }
      }
    },

    "modelo-declaration": {
      "comment": "modelo NomeDoModelo {",
      "match": "\\b(modelo)\\s+([A-Za-zÀ-ÿ_][A-Za-zÀ-ÿ0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.modelo.portugol" },
        "2": { "name": "entity.name.type.modelo.portugol" }
      }
    },

    "rota-declaration": {
      "comment": "rota \"/caminho\" {",
      "match": "\\b(rota)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.rota.portugol" }
      }
    },

    "keywords-componentes-visuais": {
      "comment": "Componentes visuais principais — cor diferente de layout",
      "patterns": [
        {
          "name": "keyword.other.component.portugol",
          "match": "\\b(titulo|subtitulo|texto|botao|entrada|imagem|video)\\b"
        }
      ]
    },

    "keywords-componentes-novos": {
      "comment": "Componentes enriquecidos — icone, ligacao, distintivo, etc.",
      "patterns": [
        {
          "name": "support.function.component.portugol",
          "match": "\\b(icone|ligacao|distintivo|divisor|lista|item|citacao|espacador)\\b"
        }
      ]
    },

    "keywords-layout": {
      "comment": "Componentes de layout",
      "patterns": [
        {
          "name": "support.class.layout.portugol",
          "match": "\\b(linha|coluna|cartao|grade)\\b"
        }
      ]
    },

    "keywords-api": {
      "patterns": [
        {
          "name": "keyword.other.http.portugol",
          "match": "\\b(obter|criar|atualizar|deletar)\\b"
        },
        {
          "name": "variable.language.attribute.portugol",
          "match": "\\b(origem|para|autor)\\b"
        }
      ]
    },

    "keywords-logica": {
      "patterns": [
        {
          "name": "keyword.control.flow.portugol",
          "match": "\\b(se|senao|retornar)\\b"
        },
        {
          "name": "keyword.control.loop.portugol",
          "match": "\\b(para|cada|em)\\b"
        },
        {
          "name": "keyword.operator.logical.portugol",
          "match": "\\b(e|ou|nao)\\b"
        }
      ]
    },

    "keywords-estilos": {
      "comment": "Propriedades de estilo — tratadas como CSS properties",
      "patterns": [
        {
          "name": "support.type.property-name.css.portugol",
          "match": "\\b(cor|fundo|largura|altura|padding|margem|borda|raio|sombra|tamanho|peso|alinhamento|espacamento|opacidade|justificar|centralizar|animacao|cursor|overflow|transicao|decoracao|maiusculas)\\b"
        }
      ]
    },

    "keywords-tipos-modelo": {
      "comment": "Tipos de campos de modelo — tratados como tipos de dados",
      "patterns": [
        {
          "name": "storage.type.datatype.portugol",
          "match": "\\b(numero|booleano|decimal|data)\\b"
        },
        {
          "name": "storage.modifier.portugol",
          "match": "\\b(unico|opcional|nao_nulo)\\b"
        }
      ]
    },

    "keywords-icones": {
      "comment": "Nomes de ícones Lucide em português — constantes",
      "patterns": [
        {
          "name": "variable.other.constant.icon.portugol",
          "match": "\\b(foguete|codigo|terminal|relampago|escudo|globo|pacote|relogio|grafico|livro|lampada|pesquisar|utilizador|utilizadores|verificar|erro|aviso|informacao|estrela|coracao|github|mail|twitter|seta_direita|seta_esquerda|seta_cima|seta_baixo|copiar|descarregar|partilhar|editar|apagar|casa|menu|fechar|notificacao|definicoes|externo)\\b"
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.portugol",
          "match": "\\b(verdadeiro|falso)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.portugol",
          "match": "(==|!=|>=|<=)"
        },
        {
          "name": "keyword.operator.relational.portugol",
          "match": "(?<![=<>!])[<>](?![=])"
        },
        {
          "name": "keyword.operator.arithmetic.portugol",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.portugol",
          "match": "(?<![=!<>])=(?![=])"
        }
      ]
    },

    "braces": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.portugol",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.portugol",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.portugol",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.portugol",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.comma.portugol",
          "match": ","
        }
      ]
    }

  }
}
