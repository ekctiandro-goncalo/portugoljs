{
  "name": "portugoljs",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace packages/compiler",
    "lint": "npx tsc --noEmit --workspaces",
    "version": "node -p \"require('./packages/compiler/package.json').version\""
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}
